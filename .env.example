# ============================================
# Mukala Web — Environment Variables
# Copy to .env.local and fill in real values
# ============================================

# --- Supabase ---
# Get these from your Supabase project: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Stripe ---
# Get these from your Stripe dashboard: https://dashboard.stripe.com/apikeys
# Test keys start with sk_test_ and pk_test_
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER_REPLACE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER_REPLACE_ME

# Stripe Price IDs for the two tiers
# Create these in Stripe dashboard → Products
STRIPE_PRICE_STANDARD=price_PLACEHOLDER_STANDARD
STRIPE_PRICE_APEX=price_PLACEHOLDER_APEX

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
